<div class="flex flex-wrap gap-2 mb-6">
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing">Overview</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/upstream">Upstream</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/rules">Rules</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/sources">IP Sources</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/manual-ips">Manual IPs</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/diagnostics">Diagnostics</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/status">Status</a>
  <a class="px-3 py-2 rounded bg-gray-100 text-gray-700" href="/servers/{{ server.id }}/routing/history">History</a>
</div>
{% if flash.success %}
  <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded">{{ flash.success }}</div>
{% endif %}
{% if flash.error %}
  <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">{{ flash.error }}</div>
{% endif %}
